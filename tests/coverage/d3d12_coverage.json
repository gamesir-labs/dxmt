        "source_regex": "DXMT_TEST_FAIL_COMPUTE_PIPELINE_CREATION_AT",
        "test_globs": ["tests/d3d12/robustness/fault_injection_spec.cpp"],
        "test_regex": "ComputePipelineFailureClearsOutputAndNextCallRecovers"
      },
      "invalid-command-recording-state": {
        "source_globs": ["src/d3d12/d3d12_command_list.cpp"],
        "source_regex": "recording_error_\\s*=\\s*E_INVALIDARG",
        "test_globs": ["tests/d3d12/sync/barrier_matrix_spec.cpp"],
        "test_regex": "InvalidBarrierFailsClose"
      },
      "corrupt-pipeline-archive-fallback": {
        "source_globs": ["src/d3d12/d3d12_pipeline.cpp"],
        "source_regex": "AttachPSOBinaryArchive",
        "test_globs": ["tests/d3d12/cache/cache_spec.cpp"],
        "test_regex": "RejectsCorruptArchiveAndFallsBackToCompilation"
      },
      "queue-feedback-error-latching": {
        "source_globs": ["src/d3d12/d3d12_device.cpp"],
        "source_regex": "HasDeviceError\\(\\)\\s*\\?\\s*DXGI_ERROR_DEVICE_REMOVED",
        "test_globs": ["tests/d3d12/queue/queue_spec.cpp"],
        "test_regex": "CommitFeedbackErrorLatchesQueueAndRejectsLaterSubmissions"
      }
    }
  },
