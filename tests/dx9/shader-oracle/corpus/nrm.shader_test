05000051 a00f0000 00000000 3f800000 3e99999a 3f000000   % def c0, 0.0, 1.0, 0.3, 0.5
0200001f 80000000 900f0000                              % dcl_position v0
0200001f 80000000 e00f0000                              % dcl_position o0
