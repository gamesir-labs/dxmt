[require]
shader model = 3.0

% Expected result: (i0, i1 * (i1 - 1) / 2, 0.0, c0)
[pixel shader d3dbc-hex]
ffff0300                                                % ps_3_0
05000051 a00f0001 00000000 3f800000 00000000 00000000   % def c1, 0, 1, 0, 0
02000001 80010000 a0000001                              % mov r0.x, c1.x
01000026 f0e40000                                       % rep i0
03000002 80010000 80000000 a0550001                     %   add r0.x, r0.x, c1.y
00000027                                                % endrep
02000001 80010800 80000000                              % mov oC0.x, r0.x
02000001 80030000 a0000001                              % mov r0.xy, c1.x
01000026 f0e40001                                       % rep i1
03000002 80010000 80550000 80000000                     %   add r0.x, r0.y, r0.x
03000002 80020000 80550000 a0550001                     %   add r0.y, r0.y, c1.y
00000027                                                % endrep
02000001 80020800 80000000                              % mov oC0.y, r0.x
02000001 80040800 a0000001                              % mov oC0.z, c1.x
02000001 80080800 a0000000                              % mov oC0.w, c0.x
0000ffff                                                % end

[test]
write cbv-f32 (0) f32(5555)
write cbv-i32 (0) i32(30)
write cbv-i32 (4) i32(4)
draw quad
probe (320, 240) f32(30, 6, 0, 5555)
write cbv-f32 (0) f32(777)
write cbv-i32 (0) i32(42)
write cbv-i32 (4) i32(5)
draw quad
probe (320, 240) f32(42, 10, 0, 777)

% Expected result: 10 * number_of_iterations
% This test is to check what happens when a limiter of -1 is passed.
% It seems that it gets interpreted as uint, so a temp is used to limit the
% number of iterations to 20 to avoid looping a huge amount of times and
% blocking the GPU.
[pixel shader d3dbc-hex]
ffff0300                                                % ps_3_0
05000051 a00f0000 00000000 41200000 3f800000 41980000   % def c0, 0, 10, 1, 19
02000001 800f0000 a0000000                              % mov r0, c0.x
02000001 80010001 a0000000                              % mov r1.x, c0.x
01000026 f0e40000                                       % rep i0
03000002 800f0002 80e40000 a0550000                     %   add r2, r0, c0.y
03000002 80020001 80000001 a0aa0000                     %   add r1.y, r1.x, c0.z
02030029 80000001 a0ff0000                              %   if_ge r1.x, c0.w
02000001 800f0000 80e40002                              %     mov r0, r2
0205002d a0aa0000 a1aa0000                              %     break_ne c0.z, -c0.z
0000002b                                                %   endif
02000001 800f0000 80e40002                              %   mov r0, r2
02000001 80010001 80550001                              %   mov r1.x, r1.y
00000027                                                % endrep
02000001 800f0800 80e40000                              % mov oC0, r0
0000ffff                                                % end

[test]
write cbv-i32(0) i32(0)
