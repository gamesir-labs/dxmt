#!/bin/sh
set -eu

remote_name=${1:-}
repo_root=$(git rev-parse --show-toplevel)
validator="$repo_root/scripts/check-commit-message.sh"
zero=0000000000000000000000000000000000000000
pending=$(mktemp "${TMPDIR:-/tmp}/dxmt-pre-push.XXXXXX")
unique=$(mktemp "${TMPDIR:-/tmp}/dxmt-pre-push.XXXXXX")
trap 'rm -f "$pending" "$unique"' EXIT HUP INT TERM

while read -r _local_ref local_oid _remote_ref remote_oid; do
  if [ "$local_oid" = "$zero" ]; then
    continue
  fi

  if [ "$remote_oid" != "$zero" ] &&
      git cat-file -e "$remote_oid^{commit}" 2>/dev/null; then
    git rev-list "$remote_oid..$local_oid" >> "$pending"
  elif [ -n "$remote_name" ]; then
    git rev-list "$local_oid" --not --remotes="$remote_name" >> "$pending"
  else
    git rev-list "$local_oid" --not --remotes >> "$pending"
  fi
done

LC_ALL=C sort -u "$pending" > "$unique"
failed=0
while read -r commit; do
  if [ -n "$commit" ] && ! "$validator" --commit "$commit"; then
    failed=1
  fi
done < "$unique"

if [ "$failed" -ne 0 ]; then
  printf '%s\n' 'push rejected: fix the commit messages above and retry' >&2
  exit 1
fi
