#!/bin/sh
set -eu

script_dir=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH='' cd -- "$script_dir/.." && pwd)
config_path=
expect_config_path=false
for argument in "$@"; do
  if [ "$expect_config_path" = true ]; then
    config_path=$argument
    expect_config_path=false
    continue
  fi
  case $argument in
    --config) expect_config_path=true ;;
    --config=*) config_path=${argument#--config=} ;;
    *) break ;;
  esac
done
if [ "$expect_config_path" = true ]; then
  printf '%s\n' 'dxmt-builder: --config requires a value' >&2
  exit 2
fi
if [ -z "$config_path" ] && [ -f "$repo_root/.dxmt-builder/config.json" ]; then
  config_path="$repo_root/.dxmt-builder/config.json"
fi

managed_root="$repo_root/.cache/managed"
if [ -n "$config_path" ]; then
  case $config_path in
    /*) ;;
    *) config_path="$PWD/$config_path" ;;
  esac
  if [ ! -f "$config_path" ]; then
    printf 'dxmt-builder: config does not exist: %s\n' "$config_path" >&2
    exit 2
  fi
  configured_root=$(python3 - "$config_path" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as config_file:
    value = json.load(config_file).get("cache_root")
if not isinstance(value, str) or not value:
    raise SystemExit(2)
print(value)
PY
  ) || {
    printf 'dxmt-builder: config must contain a string cache_root: %s\n' "$config_path" >&2
    exit 2
  }
  case $configured_root in
    /*) managed_root=$configured_root ;;
    *) managed_root="$repo_root/$configured_root" ;;
  esac
fi

mkdir -p "$managed_root"
managed_root=$(CDPATH='' cd -- "$managed_root" && pwd -P)
repo_key=$(printf '%s' "$repo_root" | shasum -a 256 | awk '{print substr($1, 1, 16)}')
build_dir="$managed_root/bootstrap/dxmt-builder/$repo_key"
lock_dir="$managed_root/locks"
lock_path="$lock_dir/dxmt-builder-bootstrap-$repo_key.lock"
owner_path="$lock_path/owner"

for tool in meson ninja; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    printf 'dxmt-builder requires %s; install prerequisites with: brew install meson ninja\n' "$tool" >&2
    exit 2
  fi
done
if ! command -v clang++ >/dev/null 2>&1; then
  printf '%s\n' 'dxmt-builder requires Apple Clang; install Xcode Command Line Tools.' >&2
  exit 2
fi

mkdir -p "$lock_dir"
while ! mkdir "$lock_path" 2>/dev/null; do
  if [ -f "$owner_path" ]; then
    owner=$(sed -n '1p' "$owner_path" 2>/dev/null || true)
    case $owner in
      ''|*[!0-9]*) ;;
      *)
        if ! kill -0 "$owner" 2>/dev/null; then
          rm -rf "$lock_path"
          continue
        fi
        ;;
    esac
  fi
  sleep 1
done
printf '%s\n' "$$" > "$owner_path"
cleanup() {
  rm -f "$owner_path"
  rmdir "$lock_path" 2>/dev/null || true
}
trap cleanup EXIT HUP INT TERM

if [ ! -f "$build_dir/meson-private/coredata.dat" ]; then
  rm -rf "$build_dir"
  meson setup "$build_dir" "$repo_root/tools/dxmt-builder" --buildtype release >&2
fi
meson compile -C "$build_dir" >&2

binary="$build_dir/dxmt-builder"
if [ ! -x "$binary" ]; then
  printf 'dxmt-builder binary was not produced: %s\n' "$binary" >&2
  exit 1
fi

cleanup
trap - EXIT HUP INT TERM
export DXMT_REPO_ROOT="$repo_root"
export DXMT_BUILDER_BINARY="$binary"
exec "$binary" "$@"
